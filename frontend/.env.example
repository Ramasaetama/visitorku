# ==============================================================
# VISITORKU - Frontend Environment Variables
# ==============================================================
# Salin file ini menjadi .env lalu sesuaikan nilainya:
#   cp .env.example .env
# ==============================================================

# Base URL untuk proxy API (digunakan oleh Vite dev server)
# Contoh: /api-stg (staging), /api (production)
VITE_API_BASE_URL=/api-stg

# URL target backend yang sebenarnya (digunakan oleh Vite proxy)
# Contoh: https://visitorku.io
VITE_API_TARGET=https://your-domain.com
